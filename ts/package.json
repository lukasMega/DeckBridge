{
  "name": "deckbridge",
  "version": "0.8.0",
  "description": "DeckBridge: an alternative to a \"Network Dock\" device (>70 USD). Bridges a USB stream deck to Elgato Stream Deck software over TCP/CORA.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "lint": "oxlint src test && eslint src test",
    "format": "oxfmt src test",
    "typecheck": "/usr/bin/time tsgo --noEmit",
    "typecheck:tsc": "/usr/bin/time tsc --noEmit",
    "test": "mise run test",
    "beforeCommit": "bun run format && bun run lint && bun run typecheck && bun run build && bun run test",
    "outdated": "npm outdated --long --depth=0 ; bun outdated",
    "audit": "bun audit",
    "knip": "knip",
    "knip:fix": "knip --fix"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.7",
    "@eslint-react/eslint-plugin": "^5.9.1",
    "@napi-rs/canvas": "^1.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260621.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^7.0.2",
    "eslint-plugin-regexp": "^3.1.1",
    "eslint-plugin-sonarjs": "4.1.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "eventemitter3": "^5.0.4",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-instrument": "^6.0.3",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "knip": "^6.26.0",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "preact": "^10.29.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  }
}
