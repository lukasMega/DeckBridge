# mise local overrides (personal env/tool overrides, not for CI/other contributors)
mise.local.toml

# Node.js
ts/node_modules/
docs-site/node_modules/

# Build outputs
ts/dist/
ts/coverage/
# Cargo workspace target (all member crates share one target dir)
rust/target/
# Vendored fork is a non-member crate with its own target dir
rust/jpeg-encoder/target/
src-tauri/target/

# Compiled binary
deckbridge
deckbridge-lite

# Tauri sidecar binaries (placed by CI or mise run bundle)
src-tauri/binaries/deckbridge-*
src-tauri/binaries/deckbridge-tray-*
src-tauri/binaries/mira-tray-*
src-tauri/binaries/mira2el-tjs-*

# txiki.js runtime (downloaded/built by mise run tjs-setup)
vendor/

# Packaged release archives
dist/

# Docs site — generated outputs (source of truth is docs-site/src + docs/)
docs-site/build/
docs-site/.docusaurus/

# macOS
.DS_Store

# Editor
.idea/
.vscode/
*.iml

# Internal tooling / working files — live locally, never published
.claude/
.mcp.json
.codegraph/
graphify-out/
tmp/
**/.cmd-history.txt
bundle-sizes*.csv
PERFORMANCE_ANALYSIS.md
CLAUDE.md
ARCHITECTURE.md
