{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeckBridge",
  "version": "0.1.0",
  "identifier": "com.lukas.deckbridge",
  "build": {
    "frontendDist": "frontend"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/deckbridge", "binaries/deckbridge-tray"],
    "category": "Utility",
    "shortDescription": "Stream Deck → Elgato relay (supervisor shell)",
    "longDescription": "Windows installer that supervises the DeckBridge relay binary: spawns it as a background sidecar, reuses its localhost web UI and deckbridge-tray system tray, and cleanly tears down the process tree on quit.",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
