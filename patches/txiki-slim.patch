+// In slim builds the native WASM runtime (WAMR) is compiled out, so core.wasm
+// is undefined. Skip installing the WebAssembly global rather than crashing the
+// bootstrap; nothing in this app uses WebAssembly.
+if (wasm) {
+    Object.defineProperty(globalThis, 'WebAssembly', {
+        enumerable: true,
+        configurable: true,
+        writable: true,
+        value: new WebAssembly()
+    });
+}
